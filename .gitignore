# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# 비밀정보 (NFR-06)
.env
# Streamlit secrets(로컬 secrets.toml에 실키가 들어갈 수 있음) — config.toml만 커밋한다
.streamlit/secrets.toml

# 빌드 산출물 — ingest 재실행으로 복원 가능
data/cache/
# data/index/는 시연 배포(Streamlit Cloud)를 위해 커밋한다 — 클라우드에서 ingest 없이 검색.
# 재빌드는 uv run python -m rag.ingest. 공개/합성 데이터라 반출 이슈 없음.

# W09 PoC 로컬 인덱스(bge-m3) — w09_poc_embed.py 재실행으로 복원 가능
data/index_poc/

# 점검 이력 — 런타임 산출물 (감사 로그는 W08에서 별도 설계)
data/history/

# 실험 산출물 — judge_experiment.py 재실행으로 복원 가능
data/eval/experiments/

# 감사 로그 — 런타임 산출물
data/audit/
